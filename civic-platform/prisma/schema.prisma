generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   @default("citizen")
  departmentId String?
  wardId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Department {
  id   String @id @default(uuid())
  name String
  code String @unique
}

model Complaint {
  id          String   @id @default(uuid())
  code        String   @unique
  title       String
  description String?
  status      String   @default("open")
  citizenId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
